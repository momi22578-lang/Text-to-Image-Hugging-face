
# Hugging Face API Configuration
# Get your token from: https://huggingface.co/settings/tokens

# Required: Your Hugging Face API token
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# Optional: Default model to use (uncomment to override default)
# DEFAULT_MODEL=black-forest-labs/FLUX.1-schnell

# Optional: Output directory for generated images
# If not specified, images will be saved in the current directory
# Create this folder manually or the script will save images in root
OUTPUT_DIR=./generated_images

# Optional: Maximum image size (uncomment to set limits)
# MAX_IMAGE_SIZE=1024

# Optional: Default image format (uncomment to change from PNG)
# IMAGE_FORMAT=PNG